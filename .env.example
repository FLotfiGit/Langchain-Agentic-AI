# LLM Provider Configuration
# Choose one provider and add your API key

# OpenAI
OPENAI_API_KEY=sk-...

# Or use Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: LangChain Configuration
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=local-development

# Optional: LangSmith (for monitoring)
# LANGSMITH_API_KEY=...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional: Other APIs
# SERPAPI_API_KEY=...
# TAVILY_API_KEY=...

# Development
DEBUG=false
LOG_LEVEL=INFO
